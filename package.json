{
  "name": "cligochi",
  "version": "0.2.0",
  "description": "Tamagotchi virtual pet plugin for OpenCode — raise a pet while you code",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./tui": "./dist/tui.jsx",
    "./server": "./dist/index.js",
    "./dist/*": "./dist/*"
  },
  "files": [
    "dist",
    "plugins",
    "README.md"
  ],
  "keywords": [
    "opencode",
    "opencode-plugin",
    "plugin",
    "tamagotchi",
    "virtual-pet",
    "tui",
    "cli",
    "pet",
    "coding-companion"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jamakase/cligochi.git"
  },
  "homepage": "https://github.com/jamakase/cligochi#readme",
  "bugs": {
    "url": "https://github.com/jamakase/cligochi/issues"
  },
  "author": "Artem Astapenko",
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.3.13"
  },
  "devDependencies": {
    "@opentui/core": "^0.1.95",
    "@opentui/solid": "^0.1.95",
    "solid-js": "^1.9.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "peerDependencies": {
    "@opentui/core": "*",
    "@opentui/solid": "*",
    "solid-js": "*"
  },
  "peerDependenciesMeta": {
    "@opentui/core": { "optional": true },
    "@opentui/solid": { "optional": true },
    "solid-js": { "optional": true }
  },
  "license": "MIT"
}
